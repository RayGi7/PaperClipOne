# ── Google Calendar (OAuth2 Service Account) ──────────────────────────────────
# Service account JSON key (base64-encoded, or provide the fields individually)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# The DJ's Google Calendar ID (usually their Gmail address)
GOOGLE_CALENDAR_ID=dj@example.com

# ── Email (Nodemailer / Gmail App Password) ───────────────────────────────────
EMAIL_FROM=dj@example.com
EMAIL_APP_PASSWORD=your-gmail-app-password
# DJ's email — receives booking notification
DJ_EMAIL=dj@example.com

# ── Database ──────────────────────────────────────────────────────────────────
# Path for SQLite DB file. On Vercel, use /tmp (ephemeral).
# For persistent storage, replace with a hosted DB connection string later.
DB_PATH=/tmp/bookings.db

# ── Admin ─────────────────────────────────────────────────────────────────────
# Simple API key to protect the /admin/bookings page for MVP
ADMIN_API_KEY=change-me-to-a-random-secret

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret
